{
	"name": "torntools-extension",
	"version": "9.0.12",
	"type": "module",
	"scripts": {
		"types:watch": "tsc --noEmit --watch --pretty",
		"dev:chrome": "concurrently --names TSC,WXT \"bun run types:watch\" \"wxt\"",
		"dev:firefox": "concurrently --names TSC,WXT \"bun run types:watch\" \"wxt -b firefox --mv3\"",
		"build": "tsc && bun run build:chrome && bun run build:firefox",
		"build:chrome": "wxt build",
		"build:firefox": "wxt build -b firefox --mv3",
		"build:userscripts": "bun tools/build-userscripts.ts",
		"build:production": "APPEND_COMMIT_HASH=false bun run build",
		"zip": "bun run zip:chrome && bun run zip:firefox",
		"zip:chrome": "wxt zip",
		"zip:firefox": "wxt zip -b firefox --mv3",
		"postinstall": "wxt prepare",
		"test": "bun test",
		"test:watch": "bun test --watch",
		"format": "biome format",
		"format:fix": "biome format --write",
		"lint:fix": "biome lint --write",
		"check:fix": "biome check --write",
		"static-items": "bun tools/update-static-items.ts"
	},
	"dependencies": {
		"@phosphor-icons/core": "^2.1.1",
		"@phosphor-icons/web": "^2.1.2",
		"@tailwindcss/vite": "^4.3.1",
		"@tanstack/table-core": "^8.21.3",
		"@webext-core/proxy-service": "^2.0.1",
		"@wxt-dev/module-svelte": "^2.0.5",
		"chart.js": "^4.5.1",
		"sortablejs": "^1.15.7",
		"source-map": "^0.7.6",
		"svelte-spa-router": "^5.1.1",
		"tailwindcss": "^4.3.1",
		"tornapi-typescript": "^6.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@fontsource-variable/geist": "^5.2.9",
		"@internationalized/date": "^3.12.2",
		"@types/bun": "^1.3.14",
		"@types/sortablejs": "^1.15.9",
		"@wxt-dev/auto-icons": "^1.1.1",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"concurrently": "^10.0.3",
		"drag-drop-touch": "^1.3.1",
		"mode-watcher": "^1.1.0",
		"phosphor-svelte": "^3.1.0",
		"shadcn-svelte": "^1.3.0",
		"svelte-sonner": "^1.1.0",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"user-agent-data-types": "^0.4.3",
		"vite": "^8.1.0",
		"vite-plugin-monkey": "^8.0.6",
		"wxt": "^0.20.27"
	}
}
